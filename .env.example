TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_HANDLE=@your_channel
TELEGRAM_CHANNEL_NAME=AI Channel

# --- Gemini: один ключ на задачу (лучше — из разных Google Cloud проектов) ---
# GEMINI_API_KEY — запасной, если ключ задачи не задан
GEMINI_API_KEY=your_gemini_api_key
GEMINI_RESEARCH_API_KEY=
GEMINI_SCRIPT_API_KEY=
GEMINI_BRAINSTORM_API_KEY=
GEMINI_CHANNEL_POST_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SCRIPT_MODEL=gemini-2.5-pro
GEMINI_SCRIPT_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash-lite,gemini-2.5-flash-lite
GEMINI_MAX_RETRIES=2
GEMINI_MAX_RETRY_DELAY_SEC=12
GEMINI_MAX_429_RETRIES=1
RESEARCH_ENABLED=true
GEMINI_RESEARCH_MODEL=gemini-2.5-flash
GEMINI_RESEARCH_FALLBACK_MODELS=gemini-2.5-flash-lite
GEMINI_CHANNEL_POST_MODEL=gemini-2.5-flash
GEMINI_CHANNEL_POST_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash
GEMINI_STEP_DELAY_SEC=0

# TTS: edge | elevenlabs
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.30
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_STYLE=0.72
ELEVENLABS_SPEED=1.10
# TTS_VOICE=ru-RU-DmitryNeural

OUTPUT_DIR=assets/output

# Фон заготовки
BACKGROUND_MODE=texture
BACKGROUND_TEXTURE=texture_navy.jpg

# Сценарий (~45 сек озвучки)
SCRIPT_MIN_WORDS=78
SCRIPT_MAX_WORDS=98
TARGET_VIDEO_DURATION_SEC=48

# Рендер
RENDER_PRESET=veryfast
RENDER_THREADS=4
